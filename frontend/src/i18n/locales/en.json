  "faq": {
    "title": "FAQ",
    "section_title": "Frequently asked questions",
    "items": [
      {
        "question": "How does AI-Learning DashBoard work?",
        "answer": "Upload lecture videos (MP4) or paste a YouTube link. The system uses AI Whisper for speech-to-text and ViT5 for summarization. The whole process takes 2-5 minutes."
      },
      {
        "question": "Can I use it for free?",
        "answer": "Yes! The Free plan allows 4 videos/day, up to 10 saved items, and 10 AI chat messages/day. No credit card required."
      },
      {
        "question": "Which languages are supported?",
        "answer": "AI Whisper supports 50+ languages including Vietnamese, English, and Japanese with high accuracy."
      },
      {
        "question": "Is my video data secure?",
        "answer": "Yes. Videos are encrypted during upload and only you have access. We comply with GDPR."
      },
      {
        "question": "Can I cancel Premium anytime?",
        "answer": "Yes, you can cancel anytime from the Settings page with no cancellation fees."
      },
      {
        "question": "What payment options are available?",
        "answer": "We support MoMo, VNPay, Visa/MasterCard, and domestic ATM payments. All transactions are SSL secured."
      }
    ]
  },
