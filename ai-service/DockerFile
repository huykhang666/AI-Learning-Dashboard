# Sử dụng Python phiên bản 3.10 dạng slim để dung lượng nhẹ và chạy AI ổn định
FROM python:3.10-slim

# Thiết lập thư mục làm việc bên trong container
WORKDIR /app

# Cài đặt các thư viện hệ thống bắt buộc (đặc biệt là ffmpeg để Whisper xử lý âm thanh)
RUN apt-get update && apt-get install -y \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Copy file requirements trước để tận dụng Docker Cache, giúp các lần build sau nhanh hơn
COPY requirements.txt .

# Tiến hành cài đặt các thư viện Python (FastAPI, Uvicorn, OpenAI Whisper, v.v.)
RUN pip install --no-cache-dir -r requirements.txt

# Copy toàn bộ mã nguồn của folder ai-service vào container
COPY . .

# Khai báo mở cổng 8000 đúng theo cấu hình của FastAPI
EXPOSE 8000

# Lệnh khởi chạy chính thức, trỏ thẳng vào file main.py nằm trong thư mục app
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]